# =============================================================================
# Sovereign MCP Blueprints — auditable-sql-mcp
# Environment Variables Template
#
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=enterprise_db
POSTGRES_USER=readonly_user
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

# --- MCP Server ---------------------------------------------------------------
MCP_SERVER_NAME=sovereign-sql-mcp
MCP_PORT=8000

# --- Audit Logging -----------------------------------------------------------
# "stdout" — logs are captured by Docker's logging driver (recommended for
#             container-native environments with a log aggregator).
# "file"   — logs are written to AUDIT_LOG_FILE (mount to WORM storage).
AUDIT_LOG_MODE=stdout
AUDIT_LOG_FILE=/var/log/mcp/audit.jsonl

# --- Data Minimisation -------------------------------------------------------
# Hard cap on rows returned per query (GDPR Art. 5(1)(c)).
# Cannot be overridden by Claude at runtime.
QUERY_MAX_ROWS=50

# --- Observability -----------------------------------------------------------
LOG_LEVEL=INFO
